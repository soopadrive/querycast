{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QueryCast",
  "version": "0.1.0",
  "identifier": "app.querycast",
  "build": {
    "frontendDist": "../",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QueryCast",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "User-controlled YouTube subscription feed.",
    "longDescription": "QueryCast replaces YouTube's algorithmic home feed with a transparent, user-controlled curation system. Each user supplies their own Google Cloud OAuth credentials so their YouTube API quota is theirs alone.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
